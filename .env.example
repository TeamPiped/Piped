# Copy this file to .env and fill in your values.
# docker compose automatically reads .env from the project root.

# ── Required for production ──────────────────────────────────────────────────
# Your public domain. Caddy provisions TLS automatically.
PIPED_DOMAIN=piped.example.com

# Must match hibernate.connection.password in config/piped.properties
POSTGRES_PASSWORD=changeme

# ── Optional ─────────────────────────────────────────────────────────────────
# Email address for Let's Encrypt expiry notices (recommended)
ACME_EMAIL=

# Override the backend API URL injected into the frontend at startup.
# Defaults to https://<PIPED_DOMAIN>/api — only change if your setup differs.
# PIPED_BACKEND_URL=https://piped.example.com/api
