# Copy this to .env before running docker compose.

# Port nginx listens on – point your reverse proxy here.
# e.g. in Caddy:  reverse_proxy localhost:8091
PORT=8091

# PostgreSQL password (must match config/piped.properties)
POSTGRES_PASSWORD=changeme

# Optional: only needed if the Piped backend needs to generate absolute URLs
# (e.g. for video stream links). Leave blank to disable – basic browsing still works.
# PIPED_EXTERNAL_URL=https://piped.yourdomain.com
