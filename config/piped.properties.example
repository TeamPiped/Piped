# Piped Backend configuration
# Copy to config/piped.properties and adjust the database password.
# Everything else works automatically — no domain config needed.

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8080

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
hibernate.connection.url=jdbc:postgresql://post:5432/piped
hibernate.connection.username=piped
hibernate.connection.password=changeme

# ── Public URLs — DO NOT CHANGE these three lines ──────────────────────────────
# nginx rewrites these placeholder values at request time using sub_filter,
# replacing them with the actual domain the user is accessing from.
# This is what makes BYOD / any-domain work — same technique as Invidious.
PROXY_PART=http://placeholder.invalid
API_URL=http://placeholder.invalid/api
FRONTEND_URL=http://placeholder.invalid

# ── Optional features ───────────────────────────────────────────────────────────
# DISABLE_REGISTRATION=false
# FEED_RETENTION=30
